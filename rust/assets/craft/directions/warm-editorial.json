{
  "id": "warm-editorial",
  "name": "Warm Editorial",
  "oneLine": "Cream background, serif display, earth-tone accents, long-form friendly.",
  "posture": {
    "density": "comfortable",
    "tone": ["warm", "considered", "literary"],
    "cornerRadius": "md",
    "shadow": "none"
  },
  "palette": {
    "bg":   { "base": "oklch(0.97 0.02 85)", "raised": "oklch(0.94 0.03 85)" },
    "text": { "primary": "oklch(0.25 0.03 55)", "secondary": "oklch(0.45 0.04 55)", "tertiary": "oklch(0.60 0.04 55)" },
    "border": { "default": "oklch(0.85 0.04 55)", "strong": "oklch(0.70 0.05 55)" },
    "brand":  { "primary": "oklch(0.48 0.10 35)", "onPrimary": "oklch(0.97 0.02 85)" },
    "state":  { "info": "oklch(0.55 0.10 225)", "success": "oklch(0.55 0.12 140)", "warning": "oklch(0.72 0.14 65)", "danger": "oklch(0.52 0.15 20)" }
  },
  "typography": {
    "stack": ["Source Serif 4", "Georgia", "Noto Serif SC"],
