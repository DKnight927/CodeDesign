{"planId":"p_sample-c_001","dsRef":"default@1.0.0","projectId":"phase0-s03-sample-c","intent":"create_screens","stepKind":"skeleton","frames":[{"frameId":"f-sre-dashboard","frameName":"SRE 实时指标看板","regions":[{"regionId":"r-top-kpi","regionName":"顶部 KPI 指标行","kind":"horizontal-bar","bg":"color.bg.elevated","items":[{"ref":"metric.card","valueTypo":"typo.mono.sm","labelTypo":"typo.label.xs"},{"ref":"metric.card","valueTypo":"typo.mono.sm","labelTypo":"typo.label.xs"},{"ref":"metric.card","valueTypo":"typo.mono.sm","labelTypo":"typo.label.xs"},{"ref":"metric.card","valueTypo":"typo.mono.sm","labelTypo":"typo.label.xs"}]},{"regionId":"r-mid-charts","regionName":"中部 2×2 图表宫格","kind":"grid","columns":2,"rows":2,"bg":"color.bg.base","items":[{"ref":"chart.timeseries","stroke":"color.data.1","bg":"color.bg.elevated"},{"ref":"chart.timeseries","stroke":"color.data.2","bg":"color.bg.elevated"},{"ref":"chart.timeseries","stroke":"color.data.3","bg":"color.bg.elevated"},{"ref":"chart.timeseries","stroke":"color.data.4","bg":"color.bg.elevated"}]},{"regionId":"r-bottom-alerts","regionName":"下部实时告警列表","kind":"table","bg":"color.bg.elevated","headerTypo":"typo.label.xs","rowRef":"table.row","columns":[{"header":"时间","cellTypo":"typo.mono.sm"},{"header":"等级","cellRef":"tag.status","statusTokens":["color.feedback.critical","color.feedback.warning","color.feedback.ok"]},{"header":"服务","cellTypo":"typo.body.sm"},{"header":"摘要","cellTypo":"typo.body.sm"},{"header":"操作","cellRef":"button.primary"}]}]}],"components_to_create":[{"componentId":"chart.timeseries","purpose":"时间序列折线面板，承载单条或多条折线，仅供数据可视化区域使用"}],"craft_asserts":[{"assert":"information-density","level":"high","scope":"global"},{"assert":"no-decorative-gradients","level":"strict"},{"assert":"data-color-isolation","level":"strict","scope":["r-mid-charts"]},{"assert":"alert-restraint","level":"strict","note":"关键告警使用小色点+灰阶文字传达，禁止大面积色块或 emoji"}],"quality_gates":[{"gate":"typography-contrast","mustPass":true},{"gate":"mono-usage-on-metrics","rule":"KPI 数值与图表轴标签须使用 typo.mono.sm"},{"gate":"data-color-hygiene","rule":"data colors 不得出现在按钮、背景、文本等非数据可视区域"}],"rationale":"SRE 实时看板骨架：采用高信息密度的深色布局，顶部横向 KPI 行使用 metric.card + mono 数值；中部 2×2 宫格使用折线面板承载数据序列，严格隔离 data colors；下部告警列表采用 table.row 结构，等级通过 tag.status 小色点与反馈色表达，避免喧宾夺主。整体遵循 tech-utility 方向，融合 Grafana 紧凑排版、Datadog 表格告警与 Linear 克制用色的参考特征。"}